# ============================================================
# .gitignore for synced ~/.claude/ repo
# Goal: share config (rules, skills, agents, commands, hooks)
# Exclude: per-machine state, secrets, transient session data
# ============================================================

# --- Per-machine state (auto-generated by Claude Code) -------
projects/
todos/
shell-snapshots/
statsig/
ide/
*.log

# --- Per-machine session and history -------------------------
history.jsonl
.credentials.json
.last-update-check
oauth_account.json
session-*.json

# --- Local-only overrides ------------------------------------
settings.local.json
*.local.json
.env
.env.*
!.env.example

# --- OS clutter ----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / tool artefacts ---------------------------------
.vscode/
.idea/
*.swp
*~

# --- Backups created by the installer ------------------------
settings.json.bak.*
*.backup
*.bak

# --- Anything you specifically want to keep machine-local ----
# Add patterns here for personal hooks you don't want to share
# e.g. work-only hooks, machine-specific notification scripts
hooks/local-*.sh

# --- Additional Mac runtime folders missed in initial draft -------
backups/
cache/
debug/
file-history/
plans/
mcp-needs-auth-cache.json
plugins/
sessions/
